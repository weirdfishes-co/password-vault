<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Vault</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/style.css" />
</head>
<body class="vault-page">

  <!-- Header / nav -->
  <header class="vault-header">
    <div class="vault-header-inner">
      <div class="vault-logo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 1C8.676 1 6 3.676 6 7v1H4a1 1 0 0 0-1 1v13a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1h-2V7c0-3.324-2.676-6-6-6zm0 2c2.276 0 4 1.724 4 4v1H8V7c0-2.276 1.724-4 4-4zm0 9a2 2 0 1 1 0 4 2 2 0 0 1 0-4z"/>
        </svg>
        Vault
      </div>
      <div class="vault-header-actions">
        <span id="lock-timer" class="lock-timer" title="Auto-lock countdown"></span>
        <a href="/entry/new" class="btn btn-primary btn-sm">+ Add</a>
        <form method="POST" action="/export" class="inline-form" id="export-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-ghost btn-sm" title="Download vault as CSV">Download</button>
        </form>
        <form method="POST" action="/logout" class="inline-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-ghost btn-sm">Lock</button>
        </form>
      </div>
    </div>
  </header>

  <main class="vault-main">
    <!-- Search -->
    <div class="search-bar-wrap">
      <div class="search-bar">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11zM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9z" clip-rule="evenodd" />
        </svg>
        <input
          type="search"
          id="search"
          placeholder="Search by title, username, or URL…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>
    </div>

    <!-- Entry count -->
    <div class="entry-count" id="entry-count">
      <%= entries.length %> <%= entries.length === 1 ? 'entry' : 'entries' %>
    </div>

    <!-- Empty state -->
    <% if (entries.length === 0) { %>
      <div class="empty-state">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2a5 5 0 1 0 0 10A5 5 0 0 0 12 2zm0 12c-5.33 0-8 2.67-8 4v2h16v-2c0-1.33-2.67-4-8-4z"/>
        </svg>
        <p>No passwords yet.</p>
        <a href="/entry/new" class="btn btn-primary">Add your first entry</a>
      </div>
    <% } %>

    <!-- Entries grid -->
    <div class="entries-grid" id="entries-grid">
      <% entries.forEach(function(entry) { %>
        <div class="entry-card" data-title="<%= entry.title.toLowerCase() %>" data-username="<%= entry.username.toLowerCase() %>" data-url="<%= entry.url.toLowerCase() %>">
          <div class="entry-card-header">
            <div class="entry-favicon">
              <div class="entry-favicon-fallback">
                <%= entry.title.charAt(0).toUpperCase() %>
              </div>
            </div>
            <div class="entry-card-title-wrap">
              <h2 class="entry-title"><%= entry.title %></h2>
              <% if (entry.username) { %>
                <span class="entry-username"><%= entry.username %></span>
              <% } %>
            </div>
          </div>

          <% if (entry.url) { %>
            <a class="entry-url" href="<%= entry.url %>" target="_blank" rel="noopener noreferrer nofollow">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path d="M12.232 4.232a2.5 2.5 0 0 1 3.536 3.536l-1.225 1.224a.75.75 0 0 0 1.061 1.06l1.224-1.224a4 4 0 0 0-5.656-5.656l-3 3a4 4 0 0 0 .225 5.865.75.75 0 0 0 .977-1.138 2.5 2.5 0 0 1-.142-3.667l3-3z" />
                <path d="M11.603 7.963a.75.75 0 0 0-.977 1.138 2.5 2.5 0 0 1 .142 3.667l-3 3a2.5 2.5 0 0 1-3.536-3.536l1.225-1.224a.75.75 0 0 0-1.061-1.06l-1.224 1.224a4 4 0 0 0 5.656 5.656l3-3a4 4 0 0 0-.225-5.865z" />
              </svg>
              <%= (() => { try { return new URL(entry.url).hostname; } catch(e) { return entry.url; } })() %>
            </a>
          <% } %>

          <div class="entry-card-actions">
            <button
              class="btn btn-ghost btn-sm copy-btn"
              data-id="<%= entry.id %>"
              title="Copy password"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path d="M7 3.5A1.5 1.5 0 0 1 8.5 2h3.879a1.5 1.5 0 0 1 1.06.44l3.122 3.12A1.5 1.5 0 0 1 17 6.622V12.5a1.5 1.5 0 0 1-1.5 1.5h-1v-3.379a3 3 0 0 0-.879-2.121L10.5 5.379A3 3 0 0 0 8.379 4.5H7v-1z" />
                <path d="M4.5 6A1.5 1.5 0 0 0 3 7.5v9A1.5 1.5 0 0 0 4.5 18h7a1.5 1.5 0 0 0 1.5-1.5v-5.879a1.5 1.5 0 0 0-.44-1.06L9.44 6.439A1.5 1.5 0 0 0 8.378 6H4.5z" />
              </svg>
              <span class="copy-label">Copy</span>
            </button>

            <a href="/entry/<%= entry.id %>/edit" class="btn btn-ghost btn-sm" title="Edit">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path d="M5.433 13.917l1.262-3.155A4 4 0 0 1 7.58 9.42l6.92-6.918a2.121 2.121 0 0 1 3 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 0 1-.65-.65z" />
                <path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0 0 10 3H4.75A2.75 2.75 0 0 0 2 5.75v9.5A2.75 2.75 0 0 0 4.75 18h9.5A2.75 2.75 0 0 0 17 15.25V10a.75.75 0 0 0-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5z" />
              </svg>
              Edit
            </a>

            <form method="POST" action="/entry/<%= entry.id %>/delete" class="inline-form delete-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn-ghost btn-sm btn-danger" title="Delete">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 0 0 6 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 1 0 .23 1.482l.149-.022.841 10.518A2.75 2.75 0 0 0 7.596 19h4.807a2.75 2.75 0 0 0 2.742-2.53l.841-10.52.149.023a.75.75 0 0 0 .23-1.482A41.03 41.03 0 0 0 14 4.193V3.75A2.75 2.75 0 0 0 11.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 0 0-1.5.06l.3 7.5a.75.75 0 1 0 1.5-.06l-.3-7.5zm4.34.06a.75.75 0 1 0-1.5-.06l-.3 7.5a.75.75 0 1 0 1.5.06l.3-7.5z" clip-rule="evenodd" />
                </svg>
                Delete
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- No search results -->
    <div class="no-results hidden" id="no-results">
      No entries match your search.
    </div>
  </main>

  <!-- Toast notification -->
  <div id="toast" class="toast hidden"></div>

  <script>
    // ── Auto-lock timer ───────────────────────────────────────────────────────
    (function () {
      const SESSION_MS = 30 * 60 * 1000;
      const WARN_MS = 5 * 60 * 1000;
      let lastActivity = Date.now();
      const timerEl = document.getElementById('lock-timer');

      function resetActivity() { lastActivity = Date.now(); }
      ['click', 'keydown', 'scroll', 'mousemove'].forEach(e =>
        document.addEventListener(e, resetActivity, { passive: true })
      );

      setInterval(function () {
        const elapsed = Date.now() - lastActivity;
        const remaining = SESSION_MS - elapsed;
        if (remaining <= 0) {
          window.location.href = '/unlock';
          return;
        }
        if (remaining <= WARN_MS) {
          const mins = Math.floor(remaining / 60000);
          const secs = Math.floor((remaining % 60000) / 1000);
          timerEl.textContent = `Auto-lock in ${mins}:${String(secs).padStart(2, '0')}`;
          timerEl.classList.add('warn');
        } else {
          timerEl.textContent = '';
          timerEl.classList.remove('warn');
        }
      }, 1000);
    })();

    // ── Search ────────────────────────────────────────────────────────────────
    (function () {
      const input = document.getElementById('search');
      const grid = document.getElementById('entries-grid');
      const noResults = document.getElementById('no-results');
      const countEl = document.getElementById('entry-count');
      const cards = Array.from(grid.querySelectorAll('.entry-card'));
      const total = cards.length;

      input.addEventListener('input', function () {
        const q = input.value.trim().toLowerCase();
        let visible = 0;
        cards.forEach(function (card) {
          const match = !q ||
            card.dataset.title.includes(q) ||
            card.dataset.username.includes(q) ||
            card.dataset.url.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        noResults.classList.toggle('hidden', visible > 0);
        countEl.textContent = q
          ? `${visible} of ${total} ${total === 1 ? 'entry' : 'entries'}`
          : `${total} ${total === 1 ? 'entry' : 'entries'}`;
      });
    })();

    // ── Copy password ─────────────────────────────────────────────────────────
    (function () {
      const toast = document.getElementById('toast');
      let clearTimer = null;

      function showToast(msg, type) {
        toast.textContent = msg;
        toast.className = 'toast ' + (type || '');
        if (clearTimer) clearTimeout(clearTimer);
        clearTimer = setTimeout(function () {
          toast.classList.add('hidden');
        }, 3000);
      }

      document.querySelectorAll('.copy-btn').forEach(function (btn) {
        btn.addEventListener('click', async function () {
          const id = btn.dataset.id;
          try {
            const res = await fetch('/entry/' + id + '/password', {
              credentials: 'same-origin',
            });
            if (!res.ok) throw new Error('Failed');
            const { password } = await res.json();
            await navigator.clipboard.writeText(password);
            const label = btn.querySelector('.copy-label');
            label.textContent = 'Copied!';
            showToast('Password copied. Clipboard will clear in 30s.', 'success');
            // Auto-clear clipboard after 30s
            setTimeout(function () {
              navigator.clipboard.writeText('').catch(() => {});
              label.textContent = 'Copy';
            }, 30000);
          } catch {
            showToast('Failed to copy password.', 'error');
          }
        });
      });
    })();

    // ── Export confirmation ───────────────────────────────────────────────────
    document.getElementById('export-form').addEventListener('submit', function (e) {
      if (!confirm('Download all vault entries as a CSV file? Only do this on a trusted device.')) e.preventDefault();
    });

    // ── Delete confirmation ───────────────────────────────────────────────────
    document.querySelectorAll('.delete-form').forEach(function (form) {
      form.addEventListener('submit', function (e) {
        if (!confirm('Delete this entry? This cannot be undone.')) e.preventDefault();
      });
    });
  </script>
</body>
</html>
