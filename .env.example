# Copy to .env for local development (never commit .env)

# REQUIRED in production — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_me_to_a_random_64_byte_hex_string

# Path to the SQLite database file
# On Railway: mount a volume at /data and set DB_PATH=/data/vault.db
DB_PATH=./vault.db

# Set to "production" on Railway
NODE_ENV=development

# Port (Railway sets this automatically)
PORT=3000
